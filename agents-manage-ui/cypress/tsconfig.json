{
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "target": "es6",
    "lib": ["es2021", "dom"],
    "sourceMap": true,
    "types": ["cypress", "node"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler"
  },
  "include": ["**/*.ts"]
}
