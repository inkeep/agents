-  if (!subAgentIds.size) {
-    return {};
-  }
-
-  const subAgents = asRecord(agentData.subAgents);
-  const overrides: Record<string, { name: string; local?: boolean }> = {};
-  for (const subAgentId of subAgentIds) {
