+          : (query?.queryChunks?.[0]?.value?.[0] ?? query.toString());
+      executedQueries.push(queryStr);
+
+      for (const [pattern, result] of Object.entries(queryResults)) {
+        if (queryStr.includes(pattern)) {
+          return result;
+        }
+      }
+      return { rows: [] };
+    }),
+  } as any;
+
+  return { db, executedQueries, queryResults };
