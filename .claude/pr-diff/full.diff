-      }
-
-      if (!references.contextReference) {
-        return match;
-      }
-
-      didReplace = true;
-      return `\${${references.contextReference}.toTemplate(${JSON.stringify(variableName)})}`;
-    }
-  );
-
-  return didReplace ? rewrittenValue : value;
-}
