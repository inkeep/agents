{
  "name": "agent-framework",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkeep/agents.git"
  },
  "author": "Inkeep <support@inkeep.com>",
  "license": "SEE LICENSE IN LICENSE.md",
  "scripts": {
    "sync:licenses": "node scripts/sync-licenses.mjs",
    "prebuild": "pnpm install --frozen-lockfile && pnpm sync:licenses",
    "build": "turbo build --filter='!agents-cookbook-templates'",
    "knip": "turbo knip",
    "dev": "turbo dev --filter=@inkeep/agents-api --filter=@inkeep/agents-manage-ui --filter=@inkeep/agents-docs --filter=@inkeep/agents-core --filter=@inkeep/agents-sdk",
    "prepack": "pnpm sync:licenses && turbo prepack",
    "dev:apis": "turbo dev:apis",
    "test": "turbo test --filter='!agents-cookbook-templates'",
    "test:e2e": "turbo test:e2e",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage --filter='!agents-cookbook-templates'",
    "coverage": "pnpm test:coverage && node scripts/merge-coverage.mjs && node scripts/generate-badges.mjs",
    "coverage:report": "node scripts/merge-coverage.mjs",
    "coverage:badges": "node scripts/generate-badges.mjs",
    "coverage:diff": "node scripts/coverage-diff.mjs",
    "coverage:enforce": "node scripts/enforce-coverage-change.mjs",
    "coverage:check": "pnpm coverage:diff && pnpm coverage:enforce",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "pnpm format:check --write",
    "format:check": "biome check --linter-enabled=false",
    "typecheck": "turbo typecheck --filter='!agents-cookbook-templates'",
    "typecheck:watch": "turbo typecheck:watch",
    "check:fast": "pnpm typecheck",
    "precheck": "pnpm install --frozen-lockfile",
    "check": "turbo check --filter='!agents-cookbook-templates' && pnpm format:check && pnpm check:env-descriptions && pnpm check:route-handler-patterns && pnpm check:dal-boundary && pnpm check:changeset-packages && pnpm check:packagemanager-sync && pnpm knip",
    "check:husky": "turbo check:husky --filter='!agents-cookbook-templates' --filter='!@inkeep/agents-docs'",
    "check:prepush": "turbo check:prepush --filter='!agents-cookbook-templates' --filter='!@inkeep/agents-docs'",
    "check:fix": "biome check --write",
    "validate:ai-artifacts": "pnpx tsx scripts/validate-ai-artifacts.ts",
    "clean": "pnpm -r --parallel exec rm -rf node_modules/ dist/ build/ .next/ .turbo/",
    "clean:turbo": "rm -rf .turbo/",
    "turbo:login": "turbo login && turbo link",
    "turbo:setup-cache": "sh scripts/setup-turbo-cache.sh",
    "prepare": "husky",
    "bump": "node scripts/quick-changeset.mjs",
    "version": "changeset version",
    "release": "changeset publish",
    "release-dev": "changeset version --snapshot dev && changeset publish --tag dev",
    "generate:keys": "bash scripts/generate-jwt-keys.sh",
    "db:generate": "pnpm --filter @inkeep/agents-core db:generate",
    "db:migrate": "pnpm --filter @inkeep/agents-core db:migrate",
    "db:drop": "pnpm --filter @inkeep/agents-core db:drop",
    "db:clean": "pnpm --filter @inkeep/agents-core db:clean",
    "db:delete": "pnpm --filter @inkeep/agents-core db:delete",
    "db:reset": "pnpm --filter @inkeep/agents-core db:reset",
    "db:check": "pnpm --filter @inkeep/agents-core db:check",
    "db:manage:generate": "pnpm --filter @inkeep/agents-core db:manage:generate",
    "db:manage:migrate": "pnpm --filter @inkeep/agents-core db:manage:migrate",
    "db:manage:drop": "pnpm --filter @inkeep/agents-core db:manage:drop",
    "db:manage:studio": "pnpm --filter @inkeep/agents-core db:manage:studio",
    "db:manage:check": "pnpm --filter @inkeep/agents-core db:manage:check",
    "db:run:generate": "pnpm --filter @inkeep/agents-core db:run:generate",
    "db:run:migrate": "pnpm --filter @inkeep/agents-core db:run:migrate",
    "db:run:drop": "pnpm --filter @inkeep/agents-core db:run:drop",
    "db:run:studio": "pnpm --filter @inkeep/agents-core db:run:studio",
    "db:run:check": "pnpm --filter @inkeep/agents-core db:run:check",
    "mcp:generate": "pnpm --filter @inkeep/agents-mcp generate",
    "workflow:profile": "node scripts/workflows/profile.mjs",
    "workflow:profile:verbose": "node scripts/workflows/profile.mjs --verbose",
    "profile:prepush": "node scripts/profile-prepush.mjs",
    "setup-dev": "node scripts/setup-dev.js",
    "setup-dev:optional": "sh scripts/setup-optional.sh",
    "optional:stop": "sh scripts/setup-optional.sh --stop",
    "optional:status": "sh scripts/setup-optional.sh --status",
    "optional:reset": "sh scripts/setup-optional.sh --reset",
    "spicedb:schema:read": "zed schema read --insecure --endpoint localhost:50051 --token dev-secret-key",
    "spicedb:read:orgs": "zed relationship read organization --insecure --endpoint localhost:50051 --token dev-secret-key",
    "spicedb:read:projects": "zed relationship read project --insecure --endpoint localhost:50051 --token dev-secret-key",
    "spicedb:sync": "bash scripts/sync-spicedb.sh",
    "spicedb:sync:apply": "bash scripts/sync-spicedb.sh --apply",
    "db:auth:init": "pnpm --filter @inkeep/agents-core db:auth:init",
    "check:migration-lineage": "node scripts/check-migration-lineage.mjs",
    "check:changeset-packages": "node scripts/check-changeset-packages.mjs",
    "check:dal-boundary": "bash scripts/lint-data-access-boundary.sh",
    "check:env-descriptions": "node scripts/check-env-descriptions.mjs",
    "check:route-handler-patterns": "node scripts/check-route-handler-patterns.mjs",
    "check:packagemanager-sync": "node scripts/check-packagemanager-sync.mjs",
    "setup-slack-dev": "tsx scripts/setup-slack-dev.ts",
    "setup-oauth-client": "tsx scripts/setup-oauth-client.ts",
    "setup-gateway-client": "tsx scripts/setup-gateway-client.ts",
    "cache-debug": "tsx scripts/cache-debug/index.ts"
  },
  "version": "0.1.0",
  "dependencies": {
    "tsdown": "^0.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@changesets/cli": "2.29.7",
    "drizzle-kit": "^0.31.5",
    "husky": "^9.1.6",
    "knip": "5.82.0",
    "lint-staged": "^16.1.5",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "turbo": "^2.7.0",
    "unique-names-generator": "^4.7.1",
    "vitest": "^3.2.4",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "agents-api/src/{domains/**/routes/**,openapi,createApp}.{ts,tsx}": [
      "bash -c 'cd agents-api && pnpm openapi:update-snapshot && git add __snapshots__/openapi.json'"
    ],
    "agents-api/**/*.{ts,tsx}": [
      "bash -c 'cd agents-api && pnpm test --passWithNoTests --reporter=verbose'"
    ],
    ".claude/agents/*.md": [
      "bash -c 'pnpm validate:ai-artifacts'"
    ],
    ".agents/skills/**/SKILL.md": [
      "bash -c 'pnpm validate:ai-artifacts'"
    ],
    "scripts/setup-optional.sh": [
      "bash -c 'cp scripts/setup-optional.sh create-agents-template/scripts/setup-optional.sh && git add create-agents-template/scripts/setup-optional.sh'"
    ],
    "scripts/generate-jwt-keys.sh": [
      "bash -c 'cp scripts/generate-jwt-keys.sh create-agents-template/scripts/generate-jwt-keys.sh && git add create-agents-template/scripts/generate-jwt-keys.sh'"
    ]
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "@workflow/core": ">=4.2.0-beta.64",
      "dompurify": ">=3.4.0",
      "fast-xml-parser": ">=5.7.0",
      "serialize-javascript": ">=7.0.5",
      "svgo": ">=3.3.3",
      "minimatch": ">=5.1.8",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "express-rate-limit": ">=8.2.2",
      "axios": ">=1.15.2",
      "@xmldom/xmldom": ">=0.8.13",
      "protobufjs": ">=7.5.6 <8 || >=8.0.2",
      "defu": ">=6.1.5",
      "flatted": ">=3.4.2",
      "kysely": ">=0.28.17 <0.29.0",
      "kysely@>=0.29.0": "0.28.17",
      "node-forge": ">=1.4.0",
      "rollup": ">=4.59.0",
      "tar": ">=7.5.11",
      "undici": ">=6.24.0",
      "next": "^16.2.6",
      "qs": ">=6.14.2",
      "devalue": ">=5.6.3",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "@opentelemetry/auto-instrumentations-node": ">=0.75.0",
      "@opentelemetry/sdk-node": ">=0.217.0",
      "@opentelemetry/exporter-prometheus": ">=0.217.0",
      "systeminformation": ">=5.31.6",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.7",
      "mermaid": ">=11.15.0",
      "uuid": ">=13.0.1",
      "samlify>uuid": "^11.1.1",
      "file-type": "21.3.2",
      "nodemailer": "8.0.5",
      "@protobufjs/utf8": ">=1.1.1",
      "ip-address": ">=10.1.1",
      "postcss": ">=8.5.10",
      "follow-redirects": ">=1.16.0",
      "@nestjs/core": ">=11.1.18",
      "yaml": ">=2.8.3",
      "brace-expansion": ">=5.0.5",
      "ws": ">=8.20.1",
      "ajv@>=6 <6.14.0": ">=6.14.0 <7",
      "ajv@>=8 <8.18.0": ">=8.18.0",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9 <9.0.6": ">=9.0.6",
      "minimatch@>=10 <10.2.1": ">=10.2.1",
      "undici@>=7 <7.24.0": ">=7.24.0",
      "path-to-regexp@<0.1.13": "0.1.13",
      "path-to-regexp@>=4 <6.3.0": "6.3.0",
      "path-to-regexp@>=8 <8.4.0": "8.4.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4 <4.0.4": ">=4.0.4"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
